# =============================================================================
# JARVIS CLI - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais
# IMPORTANTE: Nunca commite o arquivo .env no Git!
# =============================================================================

# -----------------------------------------------------------------------------
# SQL SERVER
# -----------------------------------------------------------------------------
JARVIS_DB_HOST=localhost
JARVIS_DB_PORT=1433
JARVIS_DB_NAME=JarvisDB
JARVIS_DB_USER=sa
JARVIS_DB_PASSWORD=SuaSenhaForte123!

# Connection String completa (alternativa)
JARVIS_CONNECTION_STRING=Server=${JARVIS_DB_HOST},${JARVIS_DB_PORT};Database=${JARVIS_DB_NAME};User Id=${JARVIS_DB_USER};Password=${JARVIS_DB_PASSWORD};TrustServerCertificate=True;MultipleActiveResultSets=true

# -----------------------------------------------------------------------------
# LLM PROVIDER
# -----------------------------------------------------------------------------
# Opções: openai, azure-openai, databricks, openrouter, anthropic, ollama
JARVIS_LLM_PROVIDER=databricks

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL_PLANNER=gpt-4-turbo-preview
OPENAI_MODEL_DEVELOPER=gpt-4-turbo-preview
OPENAI_MODEL_REVIEWER=gpt-4
OPENAI_MODEL_FASTCHAT=gpt-3.5-turbo

# -----------------------------------------------------------------------------
# AZURE OPENAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://seu-resource.openai.azure.com
AZURE_OPENAI_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_PLANNER=gpt-4-turbo
AZURE_OPENAI_DEPLOYMENT_DEVELOPER=gpt-4-turbo
AZURE_OPENAI_DEPLOYMENT_REVIEWER=gpt-4
AZURE_OPENAI_DEPLOYMENT_FASTCHAT=gpt-35-turbo

# -----------------------------------------------------------------------------
# DATABRICKS
# -----------------------------------------------------------------------------
DATABRICKS_BASE_URL=https://adb-XXXXXXXXX.azuredatabricks.net
DATABRICKS_TOKEN=dapi_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_MODEL_PLANNER=databricks-claude-opus-4-5
DATABRICKS_MODEL_DEVELOPER=databricks-meta-llama-3-1-405b
DATABRICKS_MODEL_REVIEWER=databricks-meta-llama-3-1-405b
DATABRICKS_MODEL_FASTCHAT=databricks-claude-haiku-4-5

# -----------------------------------------------------------------------------
# OPENROUTER
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/
OPENROUTER_ENABLE_FALLBACK=true

# -----------------------------------------------------------------------------
# ANTHROPIC
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# OLLAMA (Self-Hosted)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# EMBEDDINGS
# -----------------------------------------------------------------------------
# Provider: openai, azure-openai, databricks
JARVIS_EMBEDDINGS_PROVIDER=azure-openai

# Azure OpenAI Embeddings
AZURE_OPENAI_EMBEDDINGS_ENDPOINT=https://seu-resource.openai.azure.com
AZURE_OPENAI_EMBEDDINGS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AZURE_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# OpenAI Embeddings
OPENAI_EMBEDDINGS_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Databricks Embeddings
DATABRICKS_EMBEDDINGS_TOKEN=dapi_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_EMBEDDINGS_MODEL=databricks-bge-large-en

# -----------------------------------------------------------------------------
# GITHUB
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_USERNAME=SeuUsuario
GITHUB_USER_AGENT=JarvisAI

# -----------------------------------------------------------------------------
# GOOGLE AI STUDIO (Gemini - Free Tier)
# -----------------------------------------------------------------------------
# Obtenha sua API key gratuita em: https://ai.google.dev
GOOGLE_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# GOOGLE
# -----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=XXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXX

# Google Custom Search (opcional)
GOOGLE_SEARCH_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_SEARCH_ENGINE_ID=XXXXXXXXXXXXXXXXX

# Google Cloud (opcional)
GOOGLE_CLOUD_PROJECT_ID=seu-projeto-gcp
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_CONNECTION_STRING=localhost:6379

# Para testes
REDIS_TEST_HOST=localhost
REDIS_TEST_PORT=6379
REDIS_TEST_DATABASE=1

# -----------------------------------------------------------------------------
# QDRANT (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=jarvis_embeddings

# Para testes
QDRANT_TEST_URL=http://localhost:6333

# -----------------------------------------------------------------------------
# SEARCH
# -----------------------------------------------------------------------------
# Provider: searxng, google
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8888

# -----------------------------------------------------------------------------
# JARVIS API
# -----------------------------------------------------------------------------
JARVIS_API_URL=http://localhost:5000
JARVIS_VERSION=3.0

# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
# Loki (Logs)
LOKI_ENABLED=true
LOKI_URL=http://localhost:3100

# Prometheus Push Gateway (Métricas)
PUSHGATEWAY_URL=http://localhost:9091

# Log Level: Debug, Information, Warning, Error
LOG_LEVEL=Information

# -----------------------------------------------------------------------------
# RAG (Retrieval Augmented Generation)
# -----------------------------------------------------------------------------
RAG_ENABLED=true
RAG_COLLECTION_NAME=jarvis_projects
RAG_AUTO_INDEX=true
RAG_TOP_K=3
RAG_MIN_SCORE=0.5

# -----------------------------------------------------------------------------
# PROJECT EXECUTION
# -----------------------------------------------------------------------------
EXECUTION_TIMEOUT_DEFAULT=300
EXECUTION_TIMEOUT_PYTHON=600
EXECUTION_TIMEOUT_NODE=300
EXECUTION_LOG_DIR=logs/executions
EXECUTION_LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# TESTES (Test Environment)
# -----------------------------------------------------------------------------
# SQL Server para testes
JARVIS_TEST_SQLSERVER_CONN=Server=localhost,1433;Database=jarvis_test;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True

# Redis para testes
JARVIS_TEST_REDIS_URL=redis://localhost:6379
JARVIS_TEST_REDIS_DB=1

# Qdrant para testes
JARVIS_TEST_QDRANT_URL=http://localhost:6333

# Desabilitar observability em testes
TEST_OBSERVABILITY_ENABLED=false

# -----------------------------------------------------------------------------
# DAEMON AUTOMATION (jarvis-daemon)
# -----------------------------------------------------------------------------
# O daemon usa a API OpenAI-compatible do provider configurado.
# Defina a chave do provider escolhido no pipeline config (campo "llm.provider").
#
# Exemplos de providers e suas env vars:
#   openrouter -> OPENROUTER_API_KEY  (ja definida acima)
#   google     -> GOOGLE_API_KEY      (ja definida acima)
#   openai     -> OPENAI_API_KEY      (ja definida acima)
#   ollama     -> nenhuma chave necessaria
#   custom     -> DAEMON_LLM_API_KEY
#
# Para o pipeline SEO Blog com OpenRouter (recomendado):
#   No config_json do pipeline, use: {"llm": {"provider": "openrouter", "model": "openrouter/free"}}
#   Modelos baratos: qwen/qwen3-coder-next ($0.07/M), z-ai/glm-4.7-flash ($0.06/M)
#   Modelos gratis:  openrouter/free, meta-llama/llama-3.3-8b-instruct:free

DAEMON_LLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# WordPress publish target (para pipeline SEO)
DAEMON_WP_BASE_URL=https://seu-blog.com
DAEMON_WP_USERNAME=admin
DAEMON_WP_APP_PASSWORD=XXXX-XXXX-XXXX-XXXX

# Telegram notifications (daily summary + alerts)
# Se nao configurar, o daemon simplesmente nao envia notificacoes.
JARVIS_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
JARVIS_TELEGRAM_CHAT_ID=123456789
JARVIS_NOTIFY_HOUR=8

# Google OAuth2 (para Search Console, AdSense, GA4)
# Configure via: jarvis-daemon auth google --client-id $GOOGLE_CLIENT_ID --client-secret $GOOGLE_CLIENT_SECRET
# Os tokens sao salvos em ~/.jarvis/credentials/google.json
# GOOGLE_CLIENT_ID e GOOGLE_CLIENT_SECRET ja estao definidos acima na secao Google.

# -----------------------------------------------------------------------------
# OUTROS
# -----------------------------------------------------------------------------
# Ambiente: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# Porta da API
ASPNETCORE_URLS=http://localhost:5000

# Timezone
TZ=America/Sao_Paulo
