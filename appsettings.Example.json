      "Endpoint": "https://SEU-RESOURCE.openai.azure.com",
      "ApiKey": "SUA_CHAVE_AZURE_OPENAI_EMBEDDINGS",
      "ApiVersion": "2023-05-15",
      "Model": "text-embedding-3-small",
      "TimeoutSeconds": 30
    },

    "OpenAI": {
      "ApiKey": "sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
      "Model": "text-embedding-3-small",
      "TimeoutSeconds": 30
    },

    "Databricks": {
      "BaseUrl": "https://SEU-WORKSPACE.azuredatabricks.net",
      "Token": "SUA_CHAVE_DATABRICKS",
      "Model": "databricks-bge-large-en",
      "AvailableModels": [
        "databricks-bge-large-en",
        "databricks-gte-large-en"
      ],
      "TimeoutSeconds": 30
    }
  },

  "Jarvis": {
    "ApiUrl": "http://localhost:5000",
    "Version": "3.0"
  },

  "Search": {
    "Provider": "Searxng",
    "SearxngUrl": "http://localhost:8888",
    "_comment": "Ou configure Google Custom Search com GoogleApiKey e SearchEngineId"
  },

  "GoogleOAuth": {
    "ClientId": "SEU-CLIENT-ID.apps.googleusercontent.com"
  },

  "GoogleCloud": {
    "ProjectId": "seu-projeto-gcp",
    "Location": "us-central1",
    "VectorSearchEndpoint": "",
    "IndexId": ""
  },

  "GitHub": {
    "Token": "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
    "UserAgent": "JarvisAI",
    "Username": "SEU_USERNAME"
  },

  "RAG": {
    "Enabled": true,
    "EmbeddingModel": "text-embedding-3-small",
    "Projects": {
      "Enabled": true,
      "CollectionName": "jarvis_projects",
      "AutoIndex": true,
      "TopK": 3,
      "MinScore": 0.5
    }
  },

  "ProjectExecution": {
    "Logging": {
      "Enabled": true,
      "LogDirectory": "logs/executions",
      "RetentionDays": 30
    },
    "Timeout": {
      "DefaultSeconds": 300,
      "PythonSeconds": 600,
      "NodeSeconds": 300,
      "JavaScriptSeconds": 300,
      "LongRunningHealthCheckSeconds": 10
    },
    "LongRunningDetection": {
      "Enabled": true,
      "AutoDetect": true
    },
    "HeartbeatIntervalSeconds": 30
  },

  "Observability": {
    "Enabled": true,
    "Loki": {
      "Enabled": true,
      "Url": "http://localhost:3100"
    },
    "PushGateway": {
      "Url": "http://localhost:9091"
    },
    "MinimumLevel": "Information"
  },

  "ConversationAnalysis": {
    "RetentionDays": 30,
    "Enabled": true,
    "MaxConversationsToAnalyze": 100,
    "MaxMessagesPerConversation": 200
  }
}
