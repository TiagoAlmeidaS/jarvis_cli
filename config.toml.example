# Exemplo de configuração do Jarvis CLI (Rust)
# Baseado no appsettings.json do projeto .NET
# 
# Este arquivo deve ser copiado para ~/.jarvis/config.toml
# ou configurado no diretório do projeto como .jarvis/config.toml

# ============================================================================
# PROVEDORES DE MODELOS (LLM Providers)
# ============================================================================

# Provedor OpenAI
[model_providers.openai]
name = "OpenAI"
base_url = "https://api.openai.com/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor OpenAI Custom (para uso com proxies ou endpoints customizados)
[model_providers.openai-custom]
name = "OpenAI Custom"
base_url = "https://api.openai.com/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor Azure OpenAI (Chat Completions API)
# Usa header "api-key" ao invés de "Authorization: Bearer" para autenticação
# A URL final será: base_url/deployments/{model}/chat/completions?api-version=...
[model_providers.azure-openai]
name = "Azure OpenAI"
base_url = "https://bml-openai-agents.openai.azure.com/openai"
env_key = null
env_http_headers = { "api-key" = "AZURE_OPENAI_API_KEY" }
wire_api = "responses"
query_params = { "api-version" = "2024-08-01-preview" }
uses_chat_completions_api = true
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor Databricks
[model_providers.databricks]
name = "Databricks"
base_url = "https://adb-926216925051160.0.azuredatabricks.net/serving-endpoints"
env_key = "DATABRICKS_API_KEY"
wire_api = "responses"
http_headers = { "Content-Type" = "application/json" }
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor OpenRouter
# NOTA: Modelos free podem precisar de uses_chat_completions_api = true
# Se receber erro 404, tente adicionar: uses_chat_completions_api = true
[model_providers.openrouter]
name = "OpenRouter"
base_url = "https://openrouter.ai/api/v1"
env_key = "OPENROUTER_API_KEY"
wire_api = "responses"
# uses_chat_completions_api = true  # Descomente se modelos free retornarem 404
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor Anthropic
[model_providers.anthropic]
name = "Anthropic"
base_url = "https://api.anthropic.com/v1"
env_key = "ANTHROPIC_API_KEY"
wire_api = "responses"
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor Google AI Studio (Gemini - free tier disponivel)
# Obtenha sua API key gratuita em: https://ai.google.dev
# Modelos gratuitos: gemini-2.5-flash, gemini-2.5-flash-lite
[model_providers.google]
name = "Google AI Studio"
base_url = "https://generativelanguage.googleapis.com/v1beta/openai"
env_key = "GOOGLE_API_KEY"
wire_api = "responses"
uses_chat_completions_api = true
request_max_retries = 4
stream_max_retries = 10
stream_idle_timeout_ms = 300000

# Provedor Ollama (local)
[model_providers.ollama]
name = "Ollama"
base_url = "http://100.98.213.86:11434/v1"
env_key = null
wire_api = "responses"
request_max_retries = 2
stream_max_retries = 5
stream_idle_timeout_ms = 60000

# ============================================================================
# PERFIS DE CONFIGURAÇÃO (Profiles)
# ============================================================================

# Perfil padrão usando Databricks (conforme seu appsettings.json)
[profiles.default]
model_provider = "databricks"
model = "databricks-claude-opus-4-5"

# Perfil para Planejamento (Planner)
[profiles.planner]
model_provider = "databricks"
model = "databricks-claude-opus-4-5"

# Perfil para Desenvolvimento (Developer)
[profiles.developer]
model_provider = "databricks"
model = "databricks-meta-llama-3-1-405b"

# Perfil para Revisão (Reviewer)
[profiles.reviewer]
model_provider = "databricks"
model = "databricks-meta-llama-3-1-405b"

# Perfil para Chat Rápido (FastChat)
[profiles.fastchat]
model_provider = "databricks"
model = "databricks-claude-haiku-4-5"

# Perfil usando OpenAI
[profiles.openai]
model_provider = "openai"
model = "gpt-4o"

# Perfil usando Azure OpenAI
[profiles.azure]
model_provider = "azure-openai"
model = "gpt-4o"

# Perfil Azure com o1-mini (raciocínio)
[profiles.azure-reasoning]
model_provider = "azure-openai"
model = "o1-mini"

# Perfil usando OpenRouter (modelo premium)
[profiles.openrouter]
model_provider = "openrouter"
model = "anthropic/claude-3.5-sonnet"

# Perfil usando OpenRouter com Mistral Nemo (barato, multilingual, bom para conteudo)
# $0.02/M input + $0.04/M output — excelente custo-beneficio
[profiles.nemo]
model_provider = "openrouter"
model = "mistralai/mistral-nemo"

# Perfil usando OpenRouter com DeepHermes (24B, reasoning, ainda barato)
# $0.02/M input + $0.10/M output — melhor qualidade que nemo, com reasoning
[profiles.hermes]
model_provider = "openrouter"
model = "nousresearch/deephermes-3-mistral-24b-preview"

# Perfil usando Ollama local
[profiles.ollama]
model_provider = "ollama"
model = "llama3.2"

# ============================================================================
# AGENT LOOP (Text-Based Tool Calling para modelos locais/baratos)
# ============================================================================
# Quando habilitado, o Jarvis usa um loop autonomo (Think -> Execute -> Observe)
# para modelos que nao suportam function calling nativo (Mistral-Nemo, Phi-3, etc.)
#
# Modos:
#   "auto"       - Detecta automaticamente pelo modelo (default)
#   "text_based" - Sempre usa o agent loop (util para Ollama local)
#   "native"     - Sempre usa Responses API (function calling nativo)
#   "disabled"   - Desabilita tool calling
#
# ---------- Exemplo 1: Ollama local (default) ----------
# [agent_loop]
# mode = "auto"
# base_url = "http://localhost:11434/v1"
# model = "mistral"

# ---------- Exemplo 2: OpenRouter (recomendado) ----------
# A api_key e resolvida automaticamente a partir da env var
# OPENROUTER_API_KEY quando a base_url contem "openrouter.ai".
# Alternativamente, use api_key_env ou api_key = "env:OPENROUTER_API_KEY".
[agent_loop]
mode = "auto"
base_url = "https://openrouter.ai/api/v1"
# api_key_env = "OPENROUTER_API_KEY"     # explicito, ou deixe vazio para auto-detect
model = "mistralai/mistral-nemo"
temperature = 0.7
max_tokens = 4096
max_iterations = 25
timeout_sec = 300
max_context_tokens = 32000

# ---------- Exemplo 3: OpenAI direto ----------
# [agent_loop]
# mode = "text_based"
# base_url = "https://api.openai.com/v1"
# api_key_env = "OPENAI_API_KEY"
# model = "gpt-4o-mini"

# ============================================================================
# CONFIGURAÇÃO GLOBAL
# ============================================================================

# Provedor padrão a ser usado
model_provider = "databricks"

# Perfil padrão
profile = "default"

# Configurações do GitHub (se necessário)
[github]
token = "your_github_pat_here"
user_agent = "JarvisAI"
username = "your_github_username"

# Configurações de busca (Search)
[search]
provider = "searxng"
searxng_url = "http://100.98.213.86:8888"

# ============================================================================
# INTEGRAÇÕES DE MENSAGERIA (Messaging Integrations)
# ============================================================================

# Configuração geral de mensageria
[messaging]
# Quando false, desabilita todas as integrações de mensageria
enabled = true

# Configuração do WhatsApp Business API
[messaging.whatsapp]
enabled = true
# URL base da API do WhatsApp Business (padrão: https://graph.facebook.com/v18.0)
api_url = "https://graph.facebook.com/v18.0"
# Token de acesso (ou use variável de ambiente WHATSAPP_ACCESS_TOKEN)
access_token = "your_whatsapp_access_token"
# Token de verificação para webhook (ou use variável de ambiente WHATSAPP_VERIFY_TOKEN)
verify_token = "your_verify_token"
# ID do número de telefone (ou use variável de ambiente WHATSAPP_PHONE_NUMBER_ID)
phone_number_id = "your_phone_number_id"
# Porta do servidor webhook (padrão: 8080)
webhook_port = 8080

# Configuração do Telegram Bot API
[messaging.telegram]
enabled = true
# Token do bot obtido do BotFather (ou use variável de ambiente TELEGRAM_BOT_TOKEN)
bot_token = "your_telegram_bot_token"
# URL do webhook (opcional, para configurar via API)
webhook_url = "https://your-domain.com/telegram/webhook"
# Porta do servidor webhook (padrão: 8081)
webhook_port = 8081
# Token secreto para validação do webhook (opcional, ou use variável de ambiente TELEGRAM_WEBHOOK_SECRET)
webhook_secret = "your_webhook_secret"

# ============================================================================
# ESTRATÉGIAS DE ROTEAMENTO LLM (LLM Routing Strategies)
# ============================================================================
# Configuração de estratégias de fallback automático para pipelines do daemon.
# Quando um provedor primário falha (HTTP 429, 50x), o sistema automaticamente
# tenta os provedores de fallback na ordem especificada.
#
# Formato: [llm.strategies.<nome_da_estratégia>]
# Campos:
#   - primary: Provedor/modelo primário (formato: "provider/model")
#   - fallbacks: Lista de provedores/modelos de fallback (em ordem de preferência)

# Estratégia para tarefas que exigem contexto longo (leitura de código, transcrição de vídeo)
[llm.strategies.heavy_context]
primary = "google/gemini-2.0-flash"
fallbacks = [
    "openrouter/google/gemini-2.0-flash:free",
    "github/gpt-4o-mini"
]

# Estratégia para tarefas que exigem raciocínio lógico (code review, planejamento)
[llm.strategies.reasoning]
primary = "openrouter/deepseek/deepseek-r1:free"
fallbacks = [
    "groq/llama-3.3-70b-versatile",
    "google/gemini-2.0-flash"
]

# Estratégia para decisões rápidas de roteamento (decidir qual agente chamar)
[llm.strategies.fast_routing]
primary = "groq/llama-3.3-70b-versatile"
fallbacks = [
    "github/gpt-4o-mini"
]