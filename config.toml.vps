# =============================================================================
# Jarvis CLI — uso da infra na VPS via Tailscale (IP: 100.98.213.86)
# =============================================================================
# Copie este conteúdo para ~/.jarvis/config.toml ou mescle com seu config
# existente. Requer Tailscale ativo para alcançar a VPS.
#
# Na VPS: docker compose -f docker-compose.vps.yml up -d
# Serviços: Qdrant, Redis, Postgres. Sem Ollama; cache e analytics via Redis.
# =============================================================================

# ============================================================================
# Redis — cache e analytics (variável de ambiente)
# ============================================================================
# Não existe [cache] no config.toml do jarvis-rs; use:
#   JARVIS_REDIS_URL=redis://100.98.213.86:6379
#
# Uso: analytics (jarvis analytics); futuro: cache de embeddings e resultados
# RAG para economia de tokens quando RAG estiver habilitado.
# ============================================================================

# ============================================================================
# RAG (desligado por enquanto — sem Ollama)
# ============================================================================
# Quando for usar RAG de novo, defina um provedor de embeddings e ative:
# enabled = true; qdrant_url e postgres_url já apontam para a VPS.
[rag]
enabled = false
qdrant_url = "http://100.98.213.86:6333"
qdrant_collection = "jarvis_knowledge"
postgres_url = "postgres://jarvis:jarvis_secure_password_change_me@100.98.213.86:5432/jarvis?sslmode=disable"

# ============================================================================
# Knowledge base
# ============================================================================
[knowledge]
enabled = true
backend = "persistent"
max_results = 5
auto_learn = true
